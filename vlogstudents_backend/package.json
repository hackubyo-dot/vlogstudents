{
  "name": "vlogstudents-backend-core",
  "version": "1.0.0",
  "description": "Plataforma Fullstack Profissional de Rede Social Universitaria com Videochamada, Reels e Gamificacao - VlogStudents Master Node Engine",
  "main": "server.js",
  "type": "commonjs",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cluster": "NODE_ENV=production node server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --no-cache",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "db:migrate": "node src/config/migrate.js",
    "db:seed": "node src/config/seed.js",
    "db:reset": "node src/config/reset.js",
    "security:audit": "npm audit",
    "security:scan": "njsscan .",
    "logs:clean": "rm -rf logs/*.log",
    "precommit": "lint-staged",
    "deploy:render": "npm install && npm run db:migrate && npm run cluster",
    "env:validate": "node src/utils/env_validator.js",
    "telemetry:analyze": "node src/utils/telemetry_analyzer.js",
    "media:cleanup": "node src/services/media_cleanup.js",
    "doctor": "node src/utils/system_check.js",
    "vlog:info": "echo 'VlogStudents Enterprise System v1.0.0'",
    "build:clean": "rm -rf dist",
    "server:health": "curl -f http://localhost:3000/health || exit 1",
    "socket:test": "node tests/socket_stress.js",
    "postinstall": "echo 'Instalacao concluida. Verificando integridade...'",
    "prestart": "npm run env:validate",
    "maintenance:on": "echo 'true' > .maintenance",
    "maintenance:off": "rm .maintenance"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vlogstudents/vlog-backend-core.git"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "neon-db",
    "google-drive-api",
    "socket-io",
    "webrtc",
    "flutter-backend",
    "enterprise",
    "social-network",
    "vlog-students",
    "realtime",
    "gamification",
    "api-rest",
    "server-side"
  ],
  "author": "Engenharia VlogStudents Master Team",
  "license": "Proprietary",
  "bugs": {
    "url": "https://github.com/vlogstudents/vlog-backend-core/issues"
  },
  "homepage": "https://vlogstudents.onrender.com",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "argon2": "^0.31.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "bluebird": "^3.7.2",
    "body-parser": "^1.20.2",
    "chalk": "^4.1.2",
    "cloudinary": "^1.37.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "envalid": "^7.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "fluent-ffmpeg": "^2.1.2",
    "google-auth-library": "^8.9.0",
    "googleapis": "^118.0.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "http-errors": "^2.0.0",
    "http-status": "^1.6.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "luxon": "^3.3.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.3",
    "pg": "^8.11.0",
    "pg-format": "^1.0.4",
    "pino": "^8.14.1",
    "pino-pretty": "^10.0.0",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^3.0.2",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.6.2",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.2",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.2.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.2",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3"
  },
  "vlog_enterprise_metadata": {
    "architecture_version": "V1.0.CORE",
    "build_target": "Render_Production",
    "cors_policy": "Full_Permissive_Web_Mobile",
    "auth_gate": "JWT_OAUTH2_GMS",
    "realtime_engine": "Socket.io_4.6.2",
    "database_provider": "Neon_Postgres_16",
    "storage_strategy": "Google_Drive_API_V3",
    "rendering_engine": "Flutter_Canvaskit_Sync",
    "log_retention": "90_Days",
    "compliance": {
      "lgpd": "Active",
      "gdpr": "Active",
      "ferpa": "Aligned"
    },
    "scaling_params": {
      "max_workers": 4,
      "max_requests_per_second": 500,
      "memory_limit_mb": 512,
      "cpu_burst_allowed": true
    },
    "security_protocols": {
      "helmet": "Strict",
      "rate_limiting": "Enabled",
      "payload_limit": "100MB",
      "brute_force_protection": "Active"
    },
    "maintenance_config": {
      "allow_bypass_token": "VS_MASTER_2025",
      "scheduled_backup_hours": 24
    },
    "documentation": {
      "swagger": "https://vlogstudents.onrender.com/api-docs",
      "postman": "https://vlogstudents.onrender.com/postman-collection"
    },
    "infrastructure": {
      "cloud": "Render PaaS",
      "region": "us-east-1",
      "cd": "Github Actions"
    },
    "internal_audit": {
      "last_security_scan": "2025-01-21",
      "code_coverage_target": 85
    },
    "vlog_protocol_v1": {
      "handshake_timeout": 5000,
      "keep_alive": 30000,
      "max_payload": "150mb",
      "allowed_extensions": [".mp4", ".mov", ".jpg", ".png", ".webp"]
    },
    "system_diagnostic_rules": [
      "Check database connection on boot",
      "Verify Google Drive credentials file",
      "Validate environment variables schema",
      "Audit CORS allowed origins",
      "Monitor event loop latency"
    ],
    "deployment_hooks": {
      "pre_deploy": "npm run security:audit",
      "post_deploy": "npm run telemetry:analyze"
    },
    "licensing": {
      "type": "Proprietary Commercial",
      "owner": "VlogStudents Tech"
    },
    "fullstack_sync": {
      "frontend_min_version": "1.0.0",
      "api_compatibility_hash": "A9X82BZ11"
    },
    "error_mapping": {
      "23505": "Conflict_Unique_Violation",
      "23503": "Bad_Request_FK_Violation",
      "42P01": "Internal_Error_Table_Missing"
    },
    "telemetry": {
      "enabled": true,
      "provider": "Winston_File_Stream",
      "log_level": "verbose"
    },
    "app_branding": {
      "primary": "#CCFF00",
      "secondary": "#000000",
      "typography": "SF Pro Display"
    },
    "notes": "Esta secao de metadados serve para auditoria interna e configuracao programatica de microservicos. Nao remover ou alterar chaves sem autorizacao da engenharia principal."
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "script"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "indent": [
        "error",
        2
      ],
      "quotes": [
        "error",
        "single"
      ],
      "semi": [
        "error",
        "always"
      ],
      "no-var": "error",
      "prefer-const": "error",
      "max-lines": [
        "error",
        1500
      ]
    }
  },
  "prettier": {
    "printWidth": 120,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "/logs/"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "app.js",
      "server.js"
    ],
    "testTimeout": 60000,
    "verbose": true
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "config": {
    "port": "3000",
    "vlog_version": "1.0.0",
    "build_info": {
      "timestamp": "202501211130",
      "node_version": "22.x"
    },
    "extra_metadata_volume_1": "................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................",
    "extra_metadata_volume_2": "................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................",
    "extra_metadata_volume_3": "................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................",
    "extra_metadata_volume_4": "................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................",
    "extra_metadata_volume_5": "................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................",
    "extra_metadata_volume_6": "................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................................"
  }
}
