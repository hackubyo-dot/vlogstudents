{
  "name": "vlogstudents-backend-core",
  "version": "1.0.0",
  "description": "Plataforma Fullstack Profissional de Rede Social Universitaria com Videochamada, Reels e Gamificacao - VlogStudents",
  "main": "server.js",
  "type": "commonjs",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cluster": "NODE_ENV=production node server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --no-cache",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "db:migrate": "node src/config/migrate.js",
    "db:seed": "node src/config/seed.js",
    "db:reset": "node src/config/reset.js",
    "security:audit": "npm audit",
    "security:scan": "njsscan .",
    "logs:clean": "rm -rf logs/*.log",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "deploy:render": "npm install && npm run db:migrate && npm run cluster",
    "env:validate": "node src/utils/env_validator.js",
    "telemetry:analyze": "node src/utils/telemetry_analyzer.js",
    "media:cleanup": "node src/services/media_cleanup.js",
    "doctor": "node src/utils/system_check.js",
    "vlog:info": "echo 'VlogStudents Enterprise System v1.0.0'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vlogstudents/vlog-backend-core.git"
  },
  "keywords": [
    "nodejs",
    "express",
    "postgresql",
    "neon-db",
    "google-drive-api",
    "socket-io",
    "webrtc",
    "flutter-backend",
    "enterprise",
    "social-network",
    "vlog-students"
  ],
  "author": "Engenharia VlogStudents",
  "license": "Proprietary",
  "bugs": {
    "url": "https://github.com/vlogstudents/vlog-backend-core/issues"
  },
  "homepage": "https://vlogstudents.onrender.com",
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "argon2": "^0.31.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "bluebird": "^3.7.2",
    "body-parser": "^1.20.2",
    "chalk": "^4.1.2",
    "cloudinary": "^1.37.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto-js": "^4.1.1",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "envalid": "^7.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "fluent-ffmpeg": "^2.1.2",
    "google-auth-library": "^8.9.0",
    "googleapis": "^118.0.0",
    "helmet": "^7.0.0",
    "hpp": "^0.2.3",
    "http-errors": "^2.0.0",
    "http-status": "^1.6.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "luxon": "^3.3.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.3",
    "pg": "^8.11.0",
    "pg-format": "^1.0.4",
    "pino": "^8.14.1",
    "pino-pretty": "^10.0.0",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^3.0.2",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.6.2",
    "uuid": "^9.0.0",
    "validator": "^13.9.0",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss-clean": "^0.1.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/compression": "^1.7.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.2",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jest": "^27.2.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.2",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:prettier/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "script"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-prototype-builtins": "off",
      "no-process-exit": "off",
      "indent": [
        "error",
        2
      ],
      "linebreak-style": [
        "error",
        "unix"
      ],
      "quotes": [
        "error",
        "single"
      ],
      "semi": [
        "error",
        "always"
      ],
      "curly": [
        "error",
        "all"
      ],
      "eqeqeq": [
        "error",
        "always"
      ],
      "no-var": "error",
      "prefer-const": "error",
      "arrow-spacing": [
        "error",
        {
          "before": true,
          "after": true
        }
      ],
      "no-multiple-empty-lines": [
        "error",
        {
          "max": 1,
          "maxEOF": 0
        }
      ],
      "complexity": [
        "error",
        15
      ],
      "max-lines": [
        "error",
        {
          "max": 1000,
          "skipComments": true
        }
      ],
      "max-params": [
        "error",
        5
      ],
      "no-magic-numbers": [
        "warn",
        {
          "ignore": [
            0,
            1,
            -1,
            200,
            201,
            400,
            401,
            403,
            404,
            500
          ]
        }
      ]
    }
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/",
      "/logs/"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "app.js",
      "server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testTimeout": 30000,
    "verbose": true
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "vlogstudents_enterprise_config": {
    "deployment_target": "Render",
    "monitoring": {
      "logs_retention": "30d",
      "max_file_size": "50MB"
    },
    "database": {
      "provider": "NeonDB",
      "engine": "PostgreSQL",
      "pooling": "Enabled"
    },
    "storage": {
      "primary": "Google Drive API",
      "cdn": "Enabled"
    },
    "security": {
      "jwt_strategy": "RSA-256",
      "rate_limiting": "Strict"
    },
    "branding": {
      "primary_color": "#CCFF00",
      "secondary_color": "#121212",
      "mode": "Dark"
    },
    "api_version": "v1",
    "cluster_settings": {
      "auto_restart": true,
      "max_workers": "CPU_COUNT"
    },
    "socket_io_settings": {
      "transports": [
        "websocket"
      ],
      "path": "/socket.io"
    },
    "webrtc_settings": {
      "stun_servers": [
        "stun:stun.l.google.com:19302"
      ],
      "enable_group_calls": true
    },
    "maintenance_rules": {
      "allowed_ips": [
        "127.0.0.1"
      ],
      "enable_bypass": true
    },
    "point_system_rules": {
      "like_weight": 1,
      "comment_weight": 5,
      "post_weight": 20,
      "referral_weight": 100
    },
    "referral_config": {
      "code_length": 10,
      "case_sensitive": false
    },
    "upload_constraints": {
      "max_video_size": "100MB",
      "max_image_size": "10MB",
      "allowed_extensions": [
        "mp4",
        "mov",
        "jpg",
        "png",
        "webp"
      ]
    },
    "system_logging": {
      "error_channel": "file",
      "activity_channel": "console",
      "audit_channel": "db"
    },
    "build_information": {
      "compiled_with": "Standard Node JIT",
      "platform": "Linux/Render"
    },
    "legal_info": {
      "tos_version": "2025.1",
      "privacy_policy_version": "2025.1"
    },
    "service_account_integration": {
      "file": "credentials.json",
      "required_scopes": [
        "drive.file",
        "drive.readonly"
      ]
    },
    "scaling_params": {
      "max_concurrent_requests": 5000,
      "db_connection_limit": 50
    },
    "compression_params": {
      "level": 6,
      "threshold": "1kb"
    },
    "cors_config": {
      "allowed_origins": [
        "http://localhost:3000",
        "https://vlogstudents.onrender.com"
      ]
    },
    "auth_params": {
      "google_oauth": true,
      "jwt_session": true
    },
    "notification_config": {
      "fcm_integration": true,
      "email_notifs": true
    },
    "analytics_params": {
      "track_reels": true,
      "track_chats": false,
      "track_points": true
    },
    "developer_notes": "Este manifesto deve ser tratado como o mapa de execucao de todo o backend. Qualquer alteracao em dependencias deve ser acompanhada de auditoria de seguranca.",
    "system_health": {
      "endpoint": "/health",
      "frequency": "60s"
    },
    "redundancy_rules": [
      "Multi-region DB (Neon)",
      "Cluster-mode worker processes",
      "Auto-scaling Render instance"
    ],
    "verification_level": "Enterprise-Alpha",
    "fullstack_sync_key": "VLOG_CORE_2025_SECURE"
  }
}
